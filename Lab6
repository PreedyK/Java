public class SchoolFee extends JFrame implements ActionListener {

    JTextField feeInputField;
    JTextField deadlineEntryField;
    JLabel endMessage;

    public SchoolFee() {

        setTitle("School Fee Checker");

        feeInputField = new JTextField(15);
        deadlineEntryField = new JTextField(15);
        endMessage = new JLabel();

        JButton submitButton = new JButton("Submit");
        submitButton.addActionListener(this);

        setLayout(new GridBagLayout());
        GridBagConstraints layoutConst;

        layoutConst = new GridBagConstraints();
        layoutConst.gridx = 0;
        layoutConst.gridy = 0;
        add(new JLabel("Enter fee:"), layoutConst);

        layoutConst = new GridBagConstraints();
        layoutConst.gridx = 1;
        layoutConst.gridy = 0;
        add(feeInputField, layoutConst);

        layoutConst = new GridBagConstraints();
        layoutConst.gridx = 0;
        layoutConst.gridy = 1;
        add(new JLabel("Before deadline? (yes/no)"), layoutConst);

        layoutConst = new GridBagConstraints();
        layoutConst.gridx = 1;
        layoutConst.gridy = 1;
        add(deadlineEntryField, layoutConst);

        layoutConst = new GridBagConstraints();
        layoutConst.gridx = 0;
        layoutConst.gridy = 2;
        layoutConst.gridwidth = 2;
        add(submitButton, layoutConst);

        layoutConst = new GridBagConstraints();
        layoutConst.gridx = 0;
        layoutConst.gridy = 3;
        layoutConst.gridwidth = 2;
        add(endMessage, layoutConst);
    }

    public void actionPerformed(ActionEvent event) {
        String deadline = deadlineEntryField.getText().toLowerCase();

        if (deadline.equals("yes")) {
            endMessage.setText("On time! No extra fee.");
        } else if (deadline.equals("no")) {
            endMessage.setText("Late! Add $10 fine.");
        } else {
            endMessage.setText("Enter yes or no.");
        }
    }

    public static void main(String[] args) {
        SchoolFee myFrame = new SchoolFee();
        myFrame.setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        myFrame.pack();
        myFrame.setVisible(true);
    }
}
